{
  "name": "nexusboard",
  "version": "1.0.0",
  "description": "NexusBoard — collaborative whiteboard with video",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "dev:all": "concurrently -n backend,client -c blue,green \"npm run dev\" \"npm run dev:client\"",
    "start": "npm run start --prefix server",
    "build": "npm run build --prefix client"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
