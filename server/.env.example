# Copy to .env and fill in values. Required for production.
PORT=5000
MONGO_URI=mongodb+srv://your-cluster.mongodb.net/nexusboard
JWT_SECRET=your-secret-key-min-32-chars-for-production

# Email Configuration (Brevo API)
# Sign up free at https://brevo.com → Settings → SMTP & API → API Keys tab
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=your_verified_sender_email@gmail.com

# Optional: restrict CORS to a single origin (e.g. production frontend)
# CLIENT_URL=https://your-app.com
